GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
DJANGO_SECRET_KEY=your_django_secret_key_here
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: override the default SQLite location (backend/db.sqlite3)
# DB_PATH=/absolute/path/to/db.sqlite3

# Optional: OpenTelemetry → Jaeger (docker compose up -d from project root)
# OTEL_SERVICE_NAME=startbiz-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
